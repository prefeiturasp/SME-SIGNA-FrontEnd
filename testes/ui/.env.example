# =============================================================
# ARQUIVO DE EXEMPLO - Copie para .env e preencha com seus dados
# NÃO coloque credenciais reais neste arquivo
# =============================================================

NODE_ENV=qa

# URLs da aplicação
BASE_URL=https://qa-signa.sme.prefeitura.sp.gov.br
LOGIN_URL=https://qa-signa.sme.prefeitura.sp.gov.br/login

# Credenciais SIGNA (RF e senha do usuário de teste)
USERNAME=SEU_RF_AQUI
PASSWORD=SUA_SENHA_AQUI
SIGNA_USERNAME=SEU_RF_AQUI
SIGNA_PASSWORD=SUA_SENHA_AQUI
SIGNA_NEW_PASSWORD_TEST=NOVA_SENHA_TESTE_AQUI

# API EOL - SME Integração
API_EOL_BASE_URL=https://hom-smeintegracaoapi.sme.prefeitura.sp.gov.br
API_EOL_KEY=SUA_CHAVE_API_EOL
API_RF_LOGIN=SEU_RF_AQUI
API_PASSWORD=SUA_SENHA_AQUI
API_EMAIL=seu.email@sme.prefeitura.sp.gov.br

# Configurações do Cypress
CYPRESS_VIDEO=false
CYPRESS_SCREENSHOT=true
CYPRESS_VIEWPORT_WIDTH=1920
CYPRESS_VIEWPORT_HEIGHT=1080

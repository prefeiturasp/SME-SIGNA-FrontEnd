{
  "name": "signa-automation",
  "version": "1.0.0",
  "description": "Projeto de automação de testes para SIGNA",
  "main": "index.js",
  "scripts": {
    "test": "cypress run",
    "test:allure": "cypress run --env allure=true",
    "test:ci": "cypress run --env allure=true --browser chrome",
    "test:headed": "cypress run --headed",
    "test:chrome": "cypress run --browser chrome",
    "test:firefox": "cypress run --browser firefox",
    "test:edge": "cypress run --browser edge",
    "open": "cypress open",
    "test:login": "cypress run --spec cypress/e2e/ui/login.feature",
    "test:esqueci-senha": "cypress run --spec cypress/e2e/ui/esqueci_senha.feature",
    "test:alterar-senha": "cypress run --spec cypress/e2e/ui/alterar_senha.feature",
    "test:alteracao-email": "cypress run --spec cypress/e2e/ui/alteracao_email.feature",
    "allure:report": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report"
  },
  "keywords": [
    "cypress",
    "automation",
    "e2e",
    "testing",
    "signa"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-modules-commonjs": "^7.28.6",
    "@babel/preset-env": "^7.29.2",
    "@bahmutov/cypress-esbuild-preprocessor": "^2.2.8",
    "@cypress/webpack-preprocessor": "^5.17.1",
    "@esbuild-plugins/node-modules-polyfill": "^0.2.2",
    "@faker-js/faker": "^10.2.0",
    "@shelex/cypress-allure-plugin": "^2.41.2",
    "@types/node": "^25.3.0",
    "allure-commandline": "^2.34.1",
    "babel-loader": "^9.2.1",
    "cypress": "^14.5.4",
    "cypress-cloud": "^1.13.1",
    "cypress-cucumber-preprocessor": "^4.3.1",
    "cypress-file-upload": "^5.0.8",
    "cypress-mochawesome-reporter": "^3.8.0",
    "cypress-on-fix": "^1.1.0",
    "cypress-postgresql": "^1.0.8",
    "dotenv": "^17.2.3",
    "mocha-allure-reporter": "^1.4.0",
    "multiple-cucumber-html-reporter": "^3.5.0",
    "path-browserify": "^1.0.1",
    "process": "^0.11.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "webpack": "^5.105.0"
  },
  "cypress-cucumber-preprocessor": {
    "stepDefinitions": "cypress/support/step_definitions/**/*.js",
    "nonGlobalStepDefinitions": false,
    "json": {
      "enabled": true,
      "output": "cypress/reports/cucumber-json/cucumber-report.json"
    },
    "messages": {
      "enabled": true,
      "output": "cypress/reports/cucumber-ndjson/cucumber-report.ndjson"
    },
    "html": {
      "enabled": true,
      "output": "cypress/reports/cucumber-html/index.html"
    }
  },
  "dependencies": {
    "axios": "^1.13.2"
  }
}
